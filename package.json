{
  "name": "eta-vue",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "check": "run-p format lint types spell test knip",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "dev": "vite",
    "format": "biome check --write .",
    "lint": "eslint . --cache --fix --ignore-pattern .gitignore --max-warnings 0",
    "preview": "vite preview",
    "run": "run-s build preview",
    "spell-store": "cspell --cache --quiet --words-only --unique \"src/**/*.{txt,md,html,js,ts,vue,json,yml,py}\" > cspell-unknown-words.txt",
    "spell": "cspell --cache --quiet \"src/**/*.{txt,md,html,js,ts,vue,json,yml,py}\" \"docs/*\"",
    "test-cov": "vitest --watch=false --coverage",
    "test": "vitest --watch=false",
    "types": "vue-tsc --build",
    "knip": "knip"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "vue": "^3.5.35",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0",
    "vuetify": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@mdi/js": "^7.4.47",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "cspell": "^10.0.1",
    "cypress": "^15.17.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-vue": "~10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "npm-run-all2": "^9.0.1",
    "typescript": "~6.0.3",
    "unplugin-fonts": "^2.0.0",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
